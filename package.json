    "qa:desktop": "node scripts/verify_desktop_qa.mjs",
    "qa:ux": "node scripts/verify_ux_review.mjs",
    "qa:colors": "node scripts/verify_color_system.mjs",
    "qa:collaudo": "node scripts/verify_collaudo_storico.mjs",
    "qa:performance": "node scripts/verify_performance_runtime.mjs",
    "qa:light": "node scripts/verify_light_comfort_layout.mjs",
    "qa:master-data": "node scripts/verify_master_data_e51.mjs",
